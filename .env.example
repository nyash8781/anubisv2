# =========================================================
# Anubis-Alpha — Master env checklist
# Copy the relevant blocks to backend/.env and frontend/.env.local
# Use placeholder values only. Never commit real secrets.
# =========================================================

# -------------------------
# BACKEND (backend/.env)
# -------------------------

PORT=5000
CORS_ORIGINS=http://localhost:3000

# Anthropic / Claude (required)
ANTHROPIC_API_KEY=

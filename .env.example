# =========================================================
# Project Anubis — Environment Variables
# =========================================================
# Cloud-only deployment. No local/offline fallbacks.
#
# Copy the relevant blocks:
#   - Backend block -> backend/.env (for local dev) or Render/Railway env
#   - Frontend block -> frontend/.env.local (for local dev) or Vercel env
#
# Markers:
#   [REQUIRED]  -> app will not function without this
#   [OPTIONAL]  -> feature will no-op if missing (Phase 2 integrations)
#
# Never commit real secrets. This file uses placeholders only.
# =========================================================


# =========================================================
# BACKEND  (backend/.env  |  Render / Railway environment)
# =========================================================

# [REQUIRED] Port the Express server listens on.
# Render uses 10000 by default; Railway uses 5000. Match your host.
PORT=5000

# [REQUIRED] Comma-separated list of allowed frontend origins.
# Production: your Vercel URL (e.g. https://anubis.vercel.app)
# Local dev:  http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# [REQUIRED] Anthropic / Claude — AI generation endpoint depends on this.
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# [REQUIRED — Phase 1] Supabase — auth + persistent data.
# Get these from your Supabase project -> Settings -> API
# SUPABASE_URL is the "Project URL"
# SUPABASE_ANON_KEY is the "anon public" key
# SUPABASE_SERVICE_ROLE_KEY is the "service_role" key — BACKEND ONLY, never expose.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# [OPTIONAL — Phase 2] Resend — transactional email.
RESEND_API_KEY=

# [OPTIONAL — Phase 2] Twilio — SMS.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# [OPTIONAL — Phase 2] Cloudflare R2 — photo + file storage.
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET_NAME=

# [OPTIONAL — Phase 2] Stripe — payments.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=


# =========================================================
# FRONTEND  (frontend/.env.local  |  Vercel environment)
# =========================================================

# [REQUIRED] URL of the deployed backend. The app throws at load if missing.
# Production: https://<your-backend>.onrender.com (or Railway equivalent)
# Local dev:  http://localhost:5000
NEXT_PUBLIC_API_URL=http://localhost:5000

# [REQUIRED — Phase 1] Supabase client (browser). Same URL as backend.
# NEXT_PUBLIC_SUPABASE_ANON_KEY is the "anon public" key — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# [OPTIONAL] PostHog — analytics. App no-ops without these.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

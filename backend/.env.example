# =========================================================
# backend/.env.example
# Copy to backend/.env and fill in real values.
# =========================================================

# -------------------------
# Server
# -------------------------
PORT=5000
CORS_ORIGINS=http://localhost:3000

# -------------------------
# Anthropic / Claude (required for AI features)
# -------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# Max tokens for AI responses. 1024 is fine for follow-ups; increase to 4096 for proposals.
ANTHROPIC_MAX_TOKENS=1024

# -------------------------
# Supabase (Phase 1)
# -------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -------------------------
# Sentry (Phase 1 — error tracking)
# Create a Node.js project at sentry.io -> Settings -> Client Keys -> DSN
# -------------------------
SENTRY_DSN=

# -------------------------
# Resend (Phase 2 — email)
# -------------------------
RESEND_API_KEY=

# -------------------------
# Twilio (Phase 2 — SMS)
# -------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# -------------------------
# Cloudflare R2 (Phase 2 — file storage)
# -------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET_NAME=

# -------------------------
# Stripe (Phase 2 — payments)
# -------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
